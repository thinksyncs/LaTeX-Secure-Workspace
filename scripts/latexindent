#!/bin/sh
USER_ARGS=""
if command -v id >/dev/null 2>&1; then
    USER_ARGS="--user $(id -u):$(id -g)"
fi

if [ -n "$LATEXWORKSHOP_TMPDIR_HOST" ] && [ -n "$LATEXWORKSHOP_TMPDIR_CONTAINER" ]; then
    exec "$LATEXWORKSHOP_DOCKER_PATH" run -i --rm --pull=never --network=none \
        --cap-drop=ALL --security-opt=no-new-privileges $USER_ARGS \
        -w "$(pwd)" \
        -v "$(pwd):$(pwd)" \
        -v "$LATEXWORKSHOP_TMPDIR_HOST:$LATEXWORKSHOP_TMPDIR_CONTAINER" \
        "$LATEXWORKSHOP_DOCKER_LATEX" latexindent "$@"
fi

exec "$LATEXWORKSHOP_DOCKER_PATH" run -i --rm --pull=never --network=none \
    --cap-drop=ALL --security-opt=no-new-privileges $USER_ARGS \
    -w "$(pwd)" -v "$(pwd):$(pwd)" "$LATEXWORKSHOP_DOCKER_LATEX" latexindent "$@"
